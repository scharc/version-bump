{
  "name": "redis",
  "description": "Redis data management - keys, hashes, lists, sets, pub/sub",
  "config": {
    "command": "uvx",
    "args": ["--from", "redis-mcp-server", "redis-mcp-server"],
    "env": {
      "REDIS_HOST": "${REDIS_HOST:-localhost}",
      "REDIS_PORT": "${REDIS_PORT:-6379}",
      "REDIS_DB": "${REDIS_DB:-0}",
      "REDIS_PWD": "${REDIS_PWD:-}"
    }
  },
  "install": {
    "pip": ["redis-mcp-server"]
  },
  "notes": "Set REDIS_HOST, REDIS_PORT, REDIS_PWD in .agentbox/.env"
}
