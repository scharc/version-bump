FROM python:3.12-slim

LABEL maintainer="test@example.com"
LABEL version="1.2.3"
LABEL description="A sample application"

ARG BUILD_DATE
ENV APP_HOME=/app

WORKDIR $APP_HOME

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8080

CMD ["python", "main.py"]
